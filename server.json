{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.purmemo-ai/purmemo",
  "description": "AI conversation memory that works everywhere. Save and recall across all MCP platforms.",
  "repository": {
    "url": "https://github.com/purmemo-ai/purmemo-mcp",
    "source": "github"
  },
  "version": "15.2.2",
  "icon": {
    "src": "https://purmemo.ai/favicon.png"
  },
  "tools": [
    { "name": "save_conversation" },
    { "name": "save_artifact" },
    { "name": "recall_memories" },
    { "name": "get_memory_details" },
    { "name": "discover_related_conversations" },
    { "name": "get_user_context" },
    { "name": "run_workflow" },
    { "name": "list_workflows" },
    { "name": "share_memory" },
    { "name": "recall_public" },
    { "name": "get_public_memory" },
    { "name": "report_memory" }
  ],
  "packages": [
    {
      "registryType": "npm",
      "identifier": "purmemo-mcp",
      "version": "15.2.2",
      "runtimeHint": "node",
      "transport": {
        "type": "stdio"
      }
    }
  ]
}
