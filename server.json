{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.coladapo/purmemo",
  "description": "AI memory across Claude, ChatGPT, Gemini, and Cursor. Save, search, and recall context everywhere.",
  "repository": {
    "url": "https://github.com/coladapo/purmemo-mcp",
    "source": "github"
  },
  "version": "12.9.4",
  "icon": {
    "src": "https://purmemo.ai/favicon.png"
  },
  "packages": [
    {
      "registryType": "npm",
      "identifier": "purmemo-mcp",
      "version": "12.9.4",
      "runtimeHint": "node",
      "transport": {
        "type": "stdio"
      }
    },
    {
      "registryType": "remote",
      "identifier": "purmemo-remote",
      "version": "12.9.4",
      "transport": {
        "type": "streamable-http",
        "url": "https://mcp.purmemo.ai/mcp/messages"
      }
    }
  ]
}
